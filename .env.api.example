# =============================================================================
# OmniMedical Suite — API Service Environment Variables
# =============================================================================
# Copy this file to services/api/.env for local development.
# Generate secrets with: openssl rand -base64 32
# =============================================================================

# ─── Database ───────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:change_me@postgres:5432/omnimedical

# ─── Redis ───────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Security ───────────────────────────────────────────────────────────
API_KEY=generate_a_random_256_bit_string_here
JWT_SECRET=generate_a_random_256_bit_string_here

# ─── API Settings ───────────────────────────────────────────────────────
WORKERS=4
LOG_LEVEL=INFO
MAX_UPLOAD_SIZE=50MB
