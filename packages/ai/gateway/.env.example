# =============================================================================
# OmniFile AI Gateway - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your API keys and preferences.
#   cp .env.example .env
#
# The gateway is a universal AI model proxy for code assistants (Claude CLI, etc.)
# =============================================================================

# ---------------------------------------------------------------------------
# Provider API Keys
# ---------------------------------------------------------------------------
NVIDIA_NIM_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=
KIMI_API_KEY=
WAFER_API_KEY=

# ---------------------------------------------------------------------------
# Provider Base URLs (local providers)
# ---------------------------------------------------------------------------
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LLAMACPP_BASE_URL=http://localhost:8080/v1
OLLAMA_BASE_URL=http://localhost:11434

# ---------------------------------------------------------------------------
# Provider Proxies (optional, for tunneling through HTTP/SOCKS proxies)
# ---------------------------------------------------------------------------
# NVIDIA_NIM_PROXY=
# OPENROUTER_PROXY=
# LMSTUDIO_PROXY=
# LLAMACPP_PROXY=
# KIMI_PROXY=
# WAFER_PROXY=

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8082

# Optional: protect endpoints with Anthropic-style auth token.
# When set, clients must send: x-api-key: <ANTHROPIC_AUTH_TOKEN>
ANTHROPIC_AUTH_TOKEN=

# ---------------------------------------------------------------------------
# Model Selection
# ---------------------------------------------------------------------------
# Default model for all Claude requests (fallback).
# Format: provider_type/model/name
# Example: nvidia_nim/z-ai/glm4.7
MODEL=nvidia_nim/z-ai/glm4.7

# Per-model overrides (optional, falls back to MODEL).
# Uncomment and set to route opus/sonnet/haiku to different providers:
# MODEL_OPUS=
# MODEL_SONNET=
# MODEL_HAIKU=

# ---------------------------------------------------------------------------
# Model Discovery
# ---------------------------------------------------------------------------
# Enable automatic model discovery for supported providers.
AI_GATEWAY_MODEL_DISCOVERY=false

# ---------------------------------------------------------------------------
# Thinking / Extended Reasoning
# ---------------------------------------------------------------------------
ENABLE_MODEL_THINKING=true
# ENABLE_OPUS_THINKING=true
# ENABLE_SONNET_THINKING=true
# ENABLE_HAIKU_THINKING=true

# ---------------------------------------------------------------------------
# Provider Rate Limiting
# ---------------------------------------------------------------------------
# Max requests per provider within the rate window.
PROVIDER_RATE_LIMIT=40
# Rate window in seconds.
PROVIDER_RATE_WINDOW=60
# Max concurrent outbound requests per provider.
PROVIDER_MAX_CONCURRENCY=5

# ---------------------------------------------------------------------------
# HTTP Client Timeouts (seconds)
# ---------------------------------------------------------------------------
HTTP_READ_TIMEOUT=120
HTTP_WRITE_TIMEOUT=10
HTTP_CONNECT_TIMEOUT=10

# ---------------------------------------------------------------------------
# Optimizations
# ---------------------------------------------------------------------------
# Fast prefix detection for model routing.
FAST_PREFIX_DETECTION=true

# Mock / skip expensive operations for faster proxying:
ENABLE_NETWORK_PROBE_MOCK=true
ENABLE_TITLE_GENERATION_SKIP=true
ENABLE_SUGGESTION_MODE_SKIP=true
ENABLE_FILEPATH_EXTRACTION_MOCK=true

# ---------------------------------------------------------------------------
# Web Server Tools (web_search / web_fetch)
# ---------------------------------------------------------------------------
# Off by default: these tools perform outbound HTTP (SSRF risk).
ENABLE_WEB_SERVER_TOOLS=false

# Comma-separated URL schemes allowed for web_fetch.
WEB_FETCH_ALLOWED_SCHEMES=http,https

# Allow private/loopback IPs in web_fetch (lab only).
WEB_FETCH_ALLOW_PRIVATE_NETWORKS=false

# ---------------------------------------------------------------------------
# Assistant / CLI Integration
# ---------------------------------------------------------------------------
ASSISTANT_WORKSPACE=./agent_workspace
ASSISTANT_CLI_BIN=claude
ALLOWED_DIR=

# ---------------------------------------------------------------------------
# Debug / Diagnostic Logging
# ---------------------------------------------------------------------------
# WARNING: enabling these may log sensitive content (user messages, API payloads).
LOG_RAW_API_PAYLOADS=false
LOG_RAW_SSE_EVENTS=false
LOG_API_ERROR_TRACEBACKS=false
LOG_RAW_MESSAGING_CONTENT=false
LOG_RAW_CLI_DIAGNOSTICS=false
LOG_MESSAGING_ERROR_DETAILS=false
DEBUG_PLATFORM_EDITS=false
DEBUG_SUBAGENT_STACK=false

# ---------------------------------------------------------------------------
# Voice Note Transcription
# ---------------------------------------------------------------------------
VOICE_NOTE_ENABLED=true
WHISPER_DEVICE=cpu
WHISPER_MODEL=base
# HF_TOKEN=

# ---------------------------------------------------------------------------
# Messaging Platform (Telegram / Discord)
# ---------------------------------------------------------------------------
MESSAGING_PLATFORM=none
# MESSAGING_RATE_LIMIT=1
# MESSAGING_RATE_WINDOW=1.0

# Telegram (optional):
# TELEGRAM_BOT_TOKEN=
# ALLOWED_TELEGRAM_USER_ID=

# Discord (optional):
# DISCORD_BOT_TOKEN=
# ALLOWED_DISCORD_CHANNELS=
