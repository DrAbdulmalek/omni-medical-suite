# =============================================================================
# OmniMedical Suite — Web Frontend Environment Variables
# =============================================================================
# Copy this file to apps/web/.env.local for local development.
# Generate secrets with: openssl rand -base64 32
# =============================================================================

# ─── NextAuth (REQUIRED) ────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate_a_random_256_bit_string_here

# ─── Database (SQLite for dev, PostgreSQL for prod) ─────────────────────
# Development (SQLite):
DATABASE_URL=file:./dev.db
# Production (PostgreSQL):
# DATABASE_URL=postgresql://postgres:change_me@postgres:5432/omnimedical

# ─── Optional: API Backend URL ──────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
