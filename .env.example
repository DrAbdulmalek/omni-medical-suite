# =============================================================================
# OmniMedical Suite v2.0 — Unified Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values.
# Generate secrets with: openssl rand -base64 32
#
# For component-specific env files, see:
#   .env.web.example  — Next.js frontend variables
#   .env.api.example  — FastAPI backend variables
# =============================================================================

# ─── Database ───────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change_me_in_production
# SQLite (development):    file:./dev.db
# PostgreSQL (production): postgresql://postgres:password@host:5432/db
DATABASE_URL=postgresql://postgres:change_me_in_production@postgres:5432/omnimedical

# ─── Redis ──────────────────────────────────────────────────────────────
# Used for: caching, rate limiting (production), Celery broker
REDIS_URL=redis://redis:6379/0

# ─── Grafana ────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=change_me_in_production

# ─── Qdrant (Vector Database) ──────────────────────────────────────────
QDRANT_API_KEY=optional_api_key_for_production

# ─── Security ───────────────────────────────────────────────────────────
# Generate each with: openssl rand -base64 32
JWT_SECRET=generate_a_random_256_bit_string_here
AES_KEY=generate_a_random_256_bit_string_here
API_KEY=generate_a_random_256_bit_string_here

# ─── NextAuth (Web Frontend) ───────────────────────────────────────────
# REQUIRED for authentication — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=generate_a_random_256_bit_string_here
NEXTAUTH_URL=http://localhost:3000

# ─── API Settings ───────────────────────────────────────────────────────
WORKERS=4
LOG_LEVEL=INFO
MAX_UPLOAD_SIZE=50MB

# ─── Medical Context Protector ──────────────────────────────────────────
ENABLE_MEDICAL_PROTECTION=true
PROTECTION_STRICTNESS=high  # low | medium | high

# ─── Auto Promotion ─────────────────────────────────────────────────────
AUTO_PROMOTION_ENABLED=true
PROMOTION_FREQUENCY_THRESHOLD=3
PROMOTION_CONFIDENCE_GAIN=0.05
PROMOTION_MAX_AGE_DAYS=30

# ─── Fusion ─────────────────────────────────────────────────────────────
FUSION_SPATIAL_EPS=15.0
FUSION_MIN_CONFIDENCE=0.55
