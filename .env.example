# ============================================================================
# OmniMedical Suite — Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!
# ============================================================================

# --- Database ---
DATABASE_URL="file:./db/omni-medical.db"

# --- NextAuth ---
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="CHANGE_ME_GENERATE_WITH_openssl_rand_base64_32"

# --- Encryption (AES-256-GCM) ---
ENCRYPTION_KEY="CHANGE_ME_32_BYTE_BASE64_KEY"
# Generate: python -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"

# --- OCR Configuration ---
OCR_ENGINE_ORDER="mixed_engine,tesseract,mistral,easyocr"
TESSERACT_LANGUAGES="ara+eng"
MISTRAL_API_KEY=""
MISTRAL_MODEL="mistral-ocr-latest"
EASYOCR_GPU="false"

# --- NLP Pipeline ---
NLP_STAGES="preprocessing,correction,entity_extraction,enrichment"
NLP_LANGUAGE="ar"
ENABLE_PII_DETECTION="true"

# --- AI / LLM ---
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o"
ANTHROPIC_API_KEY=""
GOOGLE_AI_API_KEY=""

# --- Training ---
TRAINING_ALGORITHM="knn"
TRAINING_K_NEIGHBORS=5
ACTIVE_LEARNING_STRATEGY="uncertainty"

# --- File Upload ---
MAX_FILE_SIZE_MB=50
UPLOAD_DIR="./uploads"
ENCRYPTED_DIR="./encrypted"

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# --- Logging ---
LOG_LEVEL="INFO"
LOG_FILE="./logs/omni-medical.log"

# --- Redis (optional, for production) ---
REDIS_URL="redis://localhost:6379"

# --- Celery (optional, for distributed OCR) ---
CELERY_BROKER_URL="redis://localhost:6379/0"
CELERY_RESULT_BACKEND="redis://localhost:6379/1"
